---
import '../styles/global.css';
import { getLangFromUrl, useTranslations, getRouteFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  hideScroll?: boolean;
}

const { title, description = "Welcome to Łukasz Szymański's portfolio website! I am a classical musician, programmer, and filmmaker.", hideScroll = false } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const route = getRouteFromUrl(Astro.url) || '/';

const displayTitle = title === 'Home' ? 'Łukasz Szymański | szymanski.studio' : `${title} | Łukasz Szymański`;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="classical musician, programmer, filmmaker, portfolio, projects, achievements, Łukasz Szymański" />
    <meta name="author" content="Łukasz Szymański" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <title>{displayTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/screenshot.png', Astro.url)} />
    
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={displayTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/screenshot.png', Astro.url)} />

    <link rel="canonical" href={Astro.url.href.replace(/\/$/, '')} />
    <link rel="alternate" href={new URL(route, Astro.site || Astro.url.origin).href.replace(/\/$/, '')} hreflang="en" />
    <link rel="alternate" href={new URL(`/pl${route === '/' ? '' : route}`, Astro.site || Astro.url.origin).href.replace(/\/$/, '')} hreflang="pl" />
    
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://szymanski.studio/#person",
          "name": "Łukasz Szymański",
          "url": "https://szymanski.studio",
          "jobTitle": ["Musician", "Programmer", "Filmmaker"],
          "sameAs": [
            "https://github.com/Lukasz-Szymanski",
            "https://www.linkedin.com/in/lukasz-szymanski94/",
            "https://www.instagram.com/szymanski_studio/",
            "https://www.youtube.com/channel/UCKNDC6ymPscd0PPdEGr8eJw"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://szymanski.studio/#website",
          "url": "https://szymanski.studio",
          "name": "Łukasz Szymański | szymanski.studio",
          "description": "Portfolio of Łukasz Szymański: Classical Musician, Programmer, and Filmmaker.",
          "publisher": { "@id": "https://szymanski.studio/#person" },
          "inLanguage": ["en", "pl"]
        }
      ]
    })} />
    
    <script define:vars={{ currentLang: lang, currentRoute: route }}>
      // Smart Routing for language detection
      const storedLang = localStorage.getItem('user-lang');
      
      if (!storedLang) {
        const browserLang = navigator.language.toLowerCase();
        const timeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const isPolishLocation = browserLang.startsWith('pl') || timeZone === 'Europe/Warsaw';
        
        if (isPolishLocation && currentLang !== 'pl') {
          localStorage.setItem('user-lang', 'pl');
          const redirectRoute = currentRoute === '/' ? '' : currentRoute;
          window.location.replace('/pl' + redirectRoute);
        } else if (!isPolishLocation && currentLang !== 'en') {
          localStorage.setItem('user-lang', 'en');
          window.location.replace(currentRoute);
        }
      }
    </script>
  </head>
  <body class={`text-[var(--color-text-primary)] min-h-screen flex flex-col font-sans antialiased overflow-x-hidden selection:bg-blue-500/30 selection:text-blue-200 bg-transparent ${hideScroll ? 'h-screen overflow-hidden' : ''}`}>
    
    <!-- Stacking context fix: Solid background and video wrapper placed underneath -->
    <div class="fixed inset-0 -z-50 w-full h-full bg-[var(--color-bg-dark)]">
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-[var(--color-bg-dark)] z-10"></div>
      <video
        class={`w-full h-full object-cover scale-[1.01] opacity-50 ${hideScroll ? '' : 'filter blur-[0.5px]'}`}
        autoplay
        loop
        muted
        playsinline
        poster="/images/video-placeholder.jpg"
      >
        <source src="/video/showreel.webm" type="video/webm" />
        <source src="/video/showreel.mp4" type="video/mp4" />
      </video>
      
      <!-- Aurora Background Effects -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-20">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-blue-600/20 rounded-full blur-[120px] mix-blend-screen opacity-50 animate-pulse"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-indigo-600/20 rounded-full blur-[120px] mix-blend-screen opacity-50 animate-pulse" style="animation-delay: 2s;"></div>
      </div>
    </div>

    <!-- Header / Navbar -->
    <header class="fixed top-0 left-0 w-full z-45 bg-[var(--color-bg-dark)]/70 backdrop-blur-xl border-b border-[var(--color-border-apple)]/30 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-6 h-14 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <span class="font-semibold text-sm tracking-tight text-white hover:text-gray-300 transition-colors">
            Łukasz Szymański
          </span>
        </a>

        <!-- Desktop Nav (Apple style: small, centered text, clean spacing) -->
        <nav class="hidden md:flex items-center gap-8">
          <a href={lang === 'en' ? '/' : '/pl/'} class={`text-xs font-normal transition-colors duration-200 ${(currentPath === '/' || currentPath === '/pl/') ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>{t('nav.home')}</a>
          <a href={lang === 'en' ? '/programmer' : '/pl/programmer'} class={`text-xs font-normal transition-colors duration-200 ${(currentPath.endsWith('/programmer') || currentPath.endsWith('/programmer/')) ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>{t('nav.it')}</a>
          <a href={lang === 'en' ? '/audio-video' : '/pl/audio-video'} class={`text-xs font-normal transition-colors duration-200 ${(currentPath.endsWith('/audio-video') || currentPath.endsWith('/audio-video/')) ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>{t('nav.audiovideo')}</a>
          <a href={lang === 'en' ? '/about' : '/pl/about'} class={`text-xs font-normal transition-colors duration-200 ${(currentPath.endsWith('/about') || currentPath.endsWith('/about/')) ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>{t('nav.about')}</a>

          <a href={lang === 'en' ? '/contact' : '/pl/contact'} class={`text-xs font-normal transition-colors duration-200 ${(currentPath.endsWith('/contact') || currentPath.endsWith('/contact/')) ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>{t('nav.contact')}</a>
          
          <div class="flex items-center gap-2 border-l border-[var(--color-border-apple)]/30 pl-4">
            <a href={route} onclick="localStorage.setItem('user-lang', 'en')" class={`text-xs font-semibold transition-colors ${lang === 'en' ? 'text-white' : 'text-[var(--color-text-secondary)] hover:text-gray-300'}`}>EN</a>
            <span class="text-[var(--color-text-secondary)] text-xs">/</span>
            <a href={`/pl${route === '/' ? '/' : route}`} onclick="localStorage.setItem('user-lang', 'pl')" class={`text-xs font-semibold transition-colors ${lang === 'pl' ? 'text-white' : 'text-[var(--color-text-secondary)] hover:text-gray-300'}`}>PL</a>
          </div>
        </nav>

        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-toggle" aria-label="Toggle menu" class="md:hidden p-2 text-gray-300 hover:text-white focus:outline-none">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-bg-dark)]/95 border-b border-[var(--color-border-apple)]/30 backdrop-blur-2xl">
        <div class="px-6 py-4 flex flex-col gap-3">
          <a href={lang === 'en' ? '/' : '/pl/'} class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">{t('nav.home')}</a>
          <a href={lang === 'en' ? '/programmer' : '/pl/programmer'} class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">{t('nav.it')}</a>
          <a href={lang === 'en' ? '/audio-video' : '/pl/audio-video'} class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">{t('nav.audiovideo')}</a>
          <a href={lang === 'en' ? '/about' : '/pl/about'} class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">{t('nav.about')}</a>

          <a href={lang === 'en' ? '/contact' : '/pl/contact'} class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">{t('nav.contact')}</a>
          
          <div class="flex items-center justify-center gap-4 py-2 mt-2 border-t border-[var(--color-border-apple)]/30">
            <a href={route} onclick="localStorage.setItem('user-lang', 'en')" class={`text-sm font-semibold transition-colors ${lang === 'en' ? 'text-white' : 'text-[var(--color-text-secondary)] hover:text-gray-300'}`}>EN</a>
            <span class="text-[var(--color-text-secondary)] text-sm">|</span>
            <a href={`/pl${route === '/' ? '/' : route}`} onclick="localStorage.setItem('user-lang', 'pl')" class={`text-sm font-semibold transition-colors ${lang === 'pl' ? 'text-white' : 'text-[var(--color-text-secondary)] hover:text-gray-300'}`}>PL</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow pt-14 flex flex-col">
      <slot />
    </main>

    <!-- Footer Removed -->

    <!-- Interactive Scripts -->
    <script>
      // Mobile menu toggle
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-icon-open');
      const closeIcon = document.getElementById('menu-icon-close');

      if (toggleBtn && mobileMenu && openIcon && closeIcon) {
        toggleBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          if (isOpen) {
            mobileMenu.classList.add('hidden');
            openIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          } else {
            mobileMenu.classList.remove('hidden');
            openIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          }
        });
      }
    </script>
  </body>
</html>
