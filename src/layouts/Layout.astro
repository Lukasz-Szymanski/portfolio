---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  hideScroll?: boolean;
}

const { title, description = "Welcome to Łukasz Szymański's portfolio website! I am a classical musician, programmer, and filmmaker.", hideScroll = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="classical musician, programmer, filmmaker, portfolio, projects, achievements, Łukasz Szymański" />
    <meta name="author" content="Łukasz Szymański" />
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon" />
    <title>{title} | Łukasz Szymański</title>
  </head>
  <body class={`text-[var(--color-text-primary)] min-h-screen flex flex-col font-sans antialiased overflow-x-hidden selection:bg-blue-500/30 selection:text-blue-200 bg-transparent ${hideScroll ? 'h-screen overflow-hidden' : ''}`}>
    
    <!-- Stacking context fix: Solid background and video wrapper placed underneath -->
    <div class="fixed inset-0 -z-50 w-full h-full bg-[var(--color-bg-dark)]">
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-transparent to-[var(--color-bg-dark)] z-10"></div>
      <video
        class={`w-full h-full object-cover scale-[1.01] opacity-50 ${hideScroll ? '' : 'filter blur-[0.5px]'}`}
        autoplay
        loop
        muted
        playsinline
      >
        <source src="/video/showreel.mp4" type="video/mp4" />
      </video>
    </div>

    <!-- Header / Navbar -->
    <header class="fixed top-0 left-0 w-full z-45 bg-[var(--color-bg-dark)]/70 backdrop-blur-xl border-b border-[var(--color-border-apple)]/30 transition-all duration-300">
      <div class="max-w-6xl mx-auto px-6 h-14 flex justify-between items-center">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <span class="font-semibold text-sm tracking-tight text-white hover:text-gray-300 transition-colors">
            Łukasz Szymański
          </span>
        </a>

        <!-- Desktop Nav (Apple style: small, centered text, clean spacing) -->
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class={`text-xs font-normal transition-colors duration-200 ${currentPath === '/' ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>Home</a>
          <a href="/musician" class={`text-xs font-normal transition-colors duration-200 ${currentPath === '/musician' || currentPath === '/musician/' ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>Musician</a>
          <a href="/programmer" class={`text-xs font-normal transition-colors duration-200 ${currentPath === '/programmer' || currentPath === '/programmer/' ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>Programmer</a>
          <a href="/filmmaker" class={`text-xs font-normal transition-colors duration-200 ${currentPath === '/filmmaker' || currentPath === '/filmmaker/' ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>Filmmaker</a>
          <a href="/film-music" class={`text-xs font-normal transition-colors duration-200 ${currentPath === '/film-music' || currentPath === '/film-music/' ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>Film Music</a>
          <a href="/projects" class={`text-xs font-normal transition-colors duration-200 ${currentPath === '/projects' || currentPath === '/projects/' ? 'text-white font-medium' : 'text-[var(--color-text-secondary)] hover:text-white'}`}>Projects</a>
          <a href="/resume/lukasz_szymanski_resume.pdf" target="_blank" class="px-3 py-1 text-2xs font-semibold text-white bg-blue-600 hover:bg-blue-500 rounded-full shadow-sm transition-all duration-200">Resume</a>
        </nav>

        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-toggle" aria-label="Toggle menu" class="md:hidden p-2 text-gray-300 hover:text-white focus:outline-none">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-bg-dark)]/95 border-b border-[var(--color-border-apple)]/30 backdrop-blur-2xl">
        <div class="px-6 py-4 flex flex-col gap-3">
          <a href="/" class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">Home</a>
          <a href="/musician" class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">Musician</a>
          <a href="/programmer" class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">Programmer</a>
          <a href="/filmmaker" class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">Filmmaker</a>
          <a href="/film-music" class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">Film Music</a>
          <a href="/projects" class="mobile-nav-link py-1.5 text-sm text-[var(--color-text-secondary)] hover:text-white">Projects</a>
          <a href="/resume/lukasz_szymanski_resume.pdf" target="_blank" class="w-full text-center py-2 text-xs font-semibold text-white bg-blue-600 rounded-full mt-2">Resume</a>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow pt-14 flex flex-col">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-black/80 border-t border-[var(--color-border-apple)]/20 py-10 backdrop-blur-md">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
        <div>
          <p class="text-xs text-[var(--color-text-secondary)]">
            Copyright &copy; {new Date().getFullYear()} Łukasz Szymański. All rights reserved.
          </p>
        </div>

        <!-- Social Icons -->
        <div class="flex gap-5">
          <a href="https://github.com/Lukasz-Szymanski" target="_blank" aria-label="GitHub" class="text-[var(--color-text-secondary)] hover:text-white transition-colors duration-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          </a>
          <a href="https://gitlab.com/Lukasz-Szymanski" target="_blank" aria-label="GitLab" class="text-[var(--color-text-secondary)] hover:text-white transition-colors duration-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 13.29-3.33-10a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18l-2.26 6.67H8.32L6.1 3.26a.42.42 0 0 0-.1-.18.38.38 0 0 0-.26-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18L2 13.29a.74.74 0 0 0 .27.83L12 21l9.69-6.88a.71.71 0 0 0 .31-.83Z"></path></svg>
          </a>
          <a href="https://www.linkedin.com/in/lukasz-szymanski94/" target="_blank" aria-label="LinkedIn" class="text-[var(--color-text-secondary)] hover:text-white transition-colors duration-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href="https://www.instagram.com/szymanski__art/" target="_blank" aria-label="Instagram" class="text-[var(--color-text-secondary)] hover:text-white transition-colors duration-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="https://www.youtube.com/channel/UCKNDC6ymPscd0PPdEGr8eJw" target="_blank" aria-label="YouTube" class="text-[var(--color-text-secondary)] hover:text-white transition-colors duration-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          </a>
          <a href="https://twitter.com/siemabrokul" target="_blank" aria-label="Twitter X" class="text-[var(--color-text-secondary)] hover:text-white transition-colors duration-200">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path></svg>
          </a>
        </div>
      </div>
    </footer>

    <!-- Interactive Scripts -->
    <script>
      // Mobile menu toggle
      const toggleBtn = document.getElementById('mobile-menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const openIcon = document.getElementById('menu-icon-open');
      const closeIcon = document.getElementById('menu-icon-close');

      if (toggleBtn && mobileMenu && openIcon && closeIcon) {
        toggleBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden');
          if (isOpen) {
            mobileMenu.classList.add('hidden');
            openIcon.classList.remove('hidden');
            closeIcon.classList.add('hidden');
          } else {
            mobileMenu.classList.remove('hidden');
            openIcon.classList.add('hidden');
            closeIcon.classList.remove('hidden');
          }
        });
      }
    </script>
  </body>
</html>
