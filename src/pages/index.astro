---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" hideScroll={true}>
  
  <!-- Minimalist Centered Text Overlay -->
  <section class="h-[calc(100vh-3.5rem)] flex flex-col justify-center items-center px-6 select-none animate-fade-in">
    <div class="text-center space-y-6">
      
      <!-- Big Premium Typography Title -->
      <h1 class="text-5xl sm:text-7xl md:text-8xl font-semibold tracking-tight text-white leading-none">
        Łukasz Szymański
      </h1>
      
      <!-- Sleek Apple Subhead -->
      <p class="text-sm sm:text-base md:text-lg font-normal text-[var(--color-text-secondary)] uppercase tracking-[0.25em] leading-relaxed">
        Musician <span class="text-gray-600 mx-1">·</span> Developer <span class="text-gray-600 mx-1">·</span> Filmmaker
      </p>

    </div>
  </section>

</Layout>

<style>
  /* Simple Fade-In Micro-animation */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
