---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

---

<Layout title="Home" hideScroll={true}>
  
  <!-- Minimalist Centered Text Overlay -->
  <section class="relative min-h-[calc(100dvh-3.5rem)] flex flex-col justify-center items-center px-6 py-20 fade-in">
    <div class="text-center space-y-12 max-w-2xl mx-auto w-full stagger-children">
      
      <div class="space-y-6">
        <!-- Big Premium Typography Title -->
        <h1 class="font-outfit text-5xl sm:text-7xl md:text-8xl font-semibold tracking-tight text-white leading-none">
          {t('index.title')}
        </h1>
        
        <!-- Sleek Apple Subhead -->
        <p class="text-sm sm:text-base md:text-lg font-normal text-[var(--color-text-secondary)] uppercase tracking-[0.25em] leading-relaxed" set:html={t('index.subtitle')}>
        </p>
      </div>



    </div>

    <!-- Copyright (Absolute bottom) -->
    <div class="absolute bottom-6 left-0 w-full text-center fade-in" style="animation-delay: 0.8s;">
      <p class="text-[10px] text-[var(--color-text-secondary)] uppercase tracking-widest">
        Copyright &copy; {new Date().getFullYear()} {t('footer.copyright')}
      </p>
    </div>
  </section>

</Layout>


