---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { Code, Music, Film, Terminal } from '@lucide/astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Home" description={t('index.meta.desc')} hideFooter={true}>
  
  <section class="relative min-h-[calc(100dvh-3.5rem)] flex flex-col justify-center items-center px-4 sm:px-6 py-12 z-10">
    
    <div class="w-full max-w-5xl mx-auto space-y-12">
      
      <!-- Hero Header -->
      <div class="text-center space-y-6 fade-in">
        <div class="inline-flex flex-wrap items-center gap-2 px-3 py-2 rounded-[20px] bg-blue-950/30 border border-blue-500/20 text-blue-400 text-[10px] sm:text-xs font-mono mb-4 backdrop-blur-md max-w-full text-left">
          <Terminal class="w-3.5 h-3.5 shrink-0 mt-0.5 self-start" />
          <span class="typing-cursor break-all leading-relaxed" id="hero-typewriter" data-text={t('index.terminal')}></span>
        </div>
        
        <h1 class="font-outfit text-5xl sm:text-7xl md:text-8xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-white via-zinc-200 to-zinc-500 leading-none">
          {t('index.title')}
        </h1>
        
        <p class="text-sm sm:text-base md:text-lg font-medium text-zinc-400 uppercase tracking-[0.2em]" set:html={t('index.subtitle')}></p>
        
        <div class="pt-4 flex justify-center">
          <a href={`/${lang === 'pl' ? 'pl/' : ''}contact`} class="group relative inline-flex items-center justify-center gap-2 px-8 py-3 font-semibold text-white transition-all duration-300 ease-in-out bg-blue-600/20 border border-blue-500/30 rounded-full hover:bg-blue-500/30 hover:border-blue-400/50 hover:scale-105 hover:shadow-[0_0_20px_rgba(59,130,246,0.3)] backdrop-blur-md overflow-hidden">
            <span class="relative z-10">{t('index.cta')}</span>
            <div class="absolute inset-0 h-full w-full bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
          </a>
        </div>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 fade-in" style="animation-delay: 0.3s;" id="bento-grid">
        
        <!-- Main Developer Card -->
        <a href={`/${lang === 'pl' ? 'pl/' : ''}programmer`} class="bento-card group md:col-span-2 relative bg-zinc-950/40 backdrop-blur-xl border border-white/10 rounded-3xl p-8 overflow-hidden transition-transform duration-500 hover:scale-[1.02]">
          <div class="glow-effect"></div>
          <div class="relative z-10 h-full flex flex-col justify-between min-h-[200px]">
            <div class="p-3 rounded-2xl bg-blue-500/10 border border-blue-500/20 text-blue-400 w-fit">
              <Code class="w-6 h-6" />
            </div>
            <div class="mt-8">
              <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">{t('index.bento.dev.title')}</h2>
              <p class="text-zinc-400">{t('index.bento.dev.desc')}</p>
            </div>
          </div>
        </a>

        <!-- Audio-Video Card -->
        <a href={`/${lang === 'pl' ? 'pl/' : ''}audio-video`} class="bento-card group md:col-span-1 relative bg-zinc-950/40 backdrop-blur-xl border border-white/10 rounded-3xl p-6 overflow-hidden transition-transform duration-500 hover:scale-[1.02]">
          <div class="glow-effect"></div>
          <div class="relative z-10 flex flex-col h-full justify-between">
            <div class="p-2.5 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 w-fit">
              <Film class="w-5 h-5" />
            </div>
            <div class="mt-6">
              <h3 class="text-lg font-bold text-white mb-1 group-hover:text-emerald-400 transition-colors">{t('index.bento.film.title')}</h3>
              <p class="text-sm text-zinc-400">{t('index.bento.film.desc')}</p>
            </div>
          </div>
        </a>
      </div>

    </div>

    <!-- Copyright -->
    <div class="absolute bottom-6 left-0 w-full text-center fade-in" style="animation-delay: 0.8s;">
      <p class="text-[10px] text-zinc-600 uppercase tracking-widest">
        Copyright &copy; {new Date().getFullYear()} {t('footer.copyright')}
      </p>
    </div>
  </section>

</Layout>

<style>
  .typing-cursor::after {
    content: '';
    border-right: 2px solid rgba(59, 130, 246, 0.5);
    animation: blink-caret 0.75s step-end infinite;
    margin-left: 2px;
  }

  @keyframes blink-caret {
    from, to { border-color: transparent }
    50% { border-color: rgba(59, 130, 246, 0.5); }
  }

  .glow-effect {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(600px circle at var(--mouse-x) var(--mouse-y), rgba(255,255,255,0.06), transparent 40%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
    z-index: 1;
  }

  .bento-card:hover .glow-effect {
    opacity: 1;
  }

  @keyframes shimmer {
    100% {
      transform: translateX(100%);
    }
  }
</style>

<script>
  // Typewriter effect
  const typewriterEl = document.getElementById('hero-typewriter');
  if (typewriterEl) {
    const textToType = typewriterEl.getAttribute('data-text') || '';
    let i = 0;
    typewriterEl.textContent = ''; // clear initial

    function typeNextChar() {
      if (i < textToType.length) {
        typewriterEl.textContent += textToType.charAt(i);
        i++;
        // random delay for realistic typing
        const delay = Math.random() * 30 + 30; 
        setTimeout(typeNextChar, delay);
      }
    }

    setTimeout(typeNextChar, 500); // initial delay
  }

  // Mouse tracking for the glow effect on cards
  const cards = document.querySelectorAll('.bento-card');
  
  cards.forEach(card => {
    card.addEventListener('mousemove', e => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      card.style.setProperty('--mouse-x', `${x}px`);
      card.style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>
