---
import Layout from '../layouts/Layout.astro';
import { Film } from '@lucide/astro';
---

<Layout title="Filmmaker">
  
  <section class="max-w-5xl mx-auto px-6 flex-grow w-full flex items-center">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start w-full min-w-0">
      
      <!-- Left Column: Huge Apple Slogan with Gradient -->
      <div class="space-y-4 min-w-0">
        <div class="inline-flex items-center gap-2 text-blue-500">
          <Film class="h-4 w-4" />
          <span class="text-2xs font-semibold uppercase tracking-widest">Visual Frame</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-bold tracking-tight leading-[1.05] text-transparent bg-clip-text bg-gradient-to-b from-white via-zinc-100 to-zinc-300 break-words">
          Stories in motion.<br />Graded with precision.
        </h1>
      </div>

      <!-- Right Column: Biography Content in Editorial style -->
      <div class="space-y-8 font-sans min-w-0 py-12">
        
        <div class="space-y-4">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-blue-400">Cinematic Passion</h2>
          <div class="space-y-4 text-base text-[var(--color-text-secondary)] leading-relaxed text-justify">
            <p>
              Expressing storytelling through cinematic framing, lighting setups, and pacing. Video creation allows me to bridge technical filming skills with high-impact visual design.
            </p>
            <p>
              Handling all phases of production, from initial camera configurations to color grading in post-production. Experimenting with visual flow to capture authentic emotion in every sequence.
            </p>
          </div>
        </div>

        <div class="h-[1px] bg-[var(--color-border-apple)]/20"></div>

        <div class="space-y-4">
          <h2 class="text-xs font-semibold uppercase tracking-wider text-blue-400">Formats & Cooperation</h2>
          <div class="space-y-4 text-base text-[var(--color-text-secondary)] leading-relaxed text-justify">
            <p>
              Collaborating with screenwriters, sound designers, and directors to deliver unified visual projects.
            </p>
            <p>
              My portfolio includes music videos, promotional content, short-form documentaries, and commercial content. Exploring diverse formats keeps my creative cinematography fresh and engaging.
            </p>
          </div>
        </div>

      </div>

    </div>
  </section>

</Layout>
