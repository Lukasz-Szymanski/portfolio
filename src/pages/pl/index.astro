---
import Layout from '../../layouts/Layout.astro';
import { Copy } from '@lucide/astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const email = 'kontakt@szymanski.studio';

const socialLinks = [
  {
    name: 'GitHub',
    url: 'https://github.com/Lukasz-Szymanski',
    svgPath: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path>'
  },
  {
    name: 'LinkedIn',
    url: 'https://www.linkedin.com/in/lukasz-szymanski94/',
    svgPath: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle>'
  },
  {
    name: 'Instagram',
    url: 'https://www.instagram.com/szymanski__art/',
    svgPath: '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>'
  },
  {
    name: 'YouTube',
    url: 'https://www.youtube.com/channel/UCKNDC6ymPscd0PPdEGr8eJw',
    svgPath: '<path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>'
  },
  {
    name: 'Twitter / X',
    url: 'https://twitter.com/siemabrokul',
    svgPath: '<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>'
  }
];
---

<Layout title="Home" hideScroll={true}>
  
  <!-- Minimalist Centered Text Overlay -->
  <section class="relative min-h-[calc(100vh-3.5rem)] flex flex-col justify-center items-center px-6 py-20 fade-in">
    <div class="text-center space-y-12 max-w-2xl mx-auto w-full stagger-children">
      
      <div class="space-y-6">
        <!-- Big Premium Typography Title -->
        <h1 class="font-outfit text-5xl sm:text-7xl md:text-8xl font-semibold tracking-tight text-white leading-none">
          {t('index.title')}
        </h1>
        
        <!-- Sleek Apple Subhead -->
        <p class="text-sm sm:text-base md:text-lg font-normal text-[var(--color-text-secondary)] uppercase tracking-[0.25em] leading-relaxed" set:html={t('index.subtitle')}>
        </p>
      </div>

      <!-- Email Display & Action -->
      <div class="space-y-6 max-w-xl mx-auto w-full">
        <!-- Large, elegant typeface email display -->
        <div class="overflow-x-auto py-2 scrollbar-none flex justify-center">
          <a 
            href={`mailto:${email}`} 
            class="font-outfit text-xl sm:text-2xl md:text-3xl font-extralight tracking-wide text-white hover:text-blue-400 transition-colors duration-300 selection:bg-blue-500/30 break-all px-2"
          >
            {email}
          </a>
        </div>
 
        <!-- Micro-animation Copy Button -->
        <div class="flex justify-center">
          <button
            id="copy-email-btn"
            data-email={email}
            data-copied-text={t('contact.emailCopied')}
            data-copy-text={t('contact.copyEmail')}
            class="glass-pill scale-hover relative inline-flex items-center justify-center gap-2 px-6 py-3 text-xs font-medium text-gray-300 hover:text-white transition-all duration-300 active:scale-95 shadow-md group/btn overflow-hidden min-w-[160px]"
          >
            <span class="flex items-center gap-2" id="copy-btn-content">
              <Copy class="h-3.5 w-3.5 text-gray-400 group-hover/btn:text-blue-400 transition-colors" id="copy-icon" />
              <span id="copy-btn-text">{t('contact.copyEmail')}</span>
            </span>
          </button>
        </div>
      </div>

      <!-- Socials Grid -->
      <div class="space-y-4">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">{t('contact.socials')}</h2>
        
        <div class="flex flex-wrap justify-center gap-4 max-w-xl mx-auto">
          {socialLinks.map((social) => {
            return (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="glass scale-hover flex flex-col items-center justify-center w-[100px] h-[90px] p-3 text-gray-400 hover:text-white transition-all duration-300 group"
              >
                <svg class="h-5 w-5 mb-2 group-hover:text-blue-400 transition-colors duration-300 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={social.svgPath} />
                <span class="text-[10px] font-medium block truncate max-w-full text-center">{social.name}</span>
              </a>
            );
          })}
        </div>
      </div>

    </div>

    <!-- Copyright (Absolute bottom) -->
    <div class="absolute bottom-6 left-0 w-full text-center fade-in" style="animation-delay: 0.8s;">
      <p class="text-[10px] text-[var(--color-text-secondary)] uppercase tracking-widest">
        Copyright &copy; {new Date().getFullYear()} {t('footer.copyright')}
      </p>
    </div>
  </section>

</Layout>

<script>
  const copyBtn = document.getElementById('copy-email-btn');
  const copyBtnText = document.getElementById('copy-btn-text');
  const copyIcon = document.getElementById('copy-icon');

  if (copyBtn && copyBtnText && copyIcon) {
    const email = copyBtn.getAttribute('data-email') || '';
    const copiedText = copyBtn.getAttribute('data-copied-text') || 'Copied!';
    const copyText = copyBtn.getAttribute('data-copy-text') || 'Copy Email';

    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(email);

        // Animate state change
        copyBtn.classList.add('bg-blue-500/10', 'border-blue-500/40', 'text-blue-400');
        copyBtn.classList.remove('glass-pill', 'text-gray-300');
        copyBtnText.textContent = copiedText;
        
        // Temporarily replace copy icon with check icon
        copyIcon.outerHTML = `<svg id="copy-icon" class="h-3.5 w-3.5 text-blue-400 animate-scale-up" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;

        setTimeout(() => {
          const currentIcon = document.getElementById('copy-icon');
          if (currentIcon) {
            currentIcon.outerHTML = `<svg id="copy-icon" class="h-3.5 w-3.5 text-gray-400 group-hover/btn:text-blue-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;
          }
          copyBtn.classList.remove('bg-blue-500/10', 'border-blue-500/40', 'text-blue-400');
          copyBtn.classList.add('glass-pill', 'text-gray-300');
          copyBtnText.textContent = copyText;
        }, 2000);
      } catch (err) {
        console.error('Failed to copy email: ', err);
      }
    });
  }
</script>

<style>
  /* Hide scrollbar utility */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  @keyframes scaleUp {
    0% { transform: scale(0.8); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  :global(.animate-scale-up) {
    animation: scaleUp 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
</style>
