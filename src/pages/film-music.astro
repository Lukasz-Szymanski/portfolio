---
import Layout from '../layouts/Layout.astro';
import { Film, Music, PlayCircle, Headphones } from '@lucide/astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);


const soundtracks = [
  {
    title: t('soundtrack.1.title'),
    director: t('soundtrack.1.director'),
    description: t('soundtrack.1.desc'),
    genre: t('soundtrack.1.genre'),
    year: "2025",
    icon: Film,
    url: "https://www.youtube.com/watch?v=dqFi5vlX7Mk"
  },
  {
    title: t('soundtrack.2.title'),
    director: t('soundtrack.2.director'),
    description: t('soundtrack.2.desc'),
    genre: t('soundtrack.2.genre'),
    year: "2022",
    icon: Music
  },
  {
    title: t('soundtrack.3.title'),
    director: t('soundtrack.3.director'),
    description: t('soundtrack.3.desc'),
    genre: t('soundtrack.3.genre'),
    year: "2021",
    icon: Headphones
  }
];
---

<Layout title="Film Music">
  
  <section class="max-w-5xl mx-auto px-6 flex-grow w-full flex flex-col pt-12 pb-24">
    <!-- Header -->
    <div class="space-y-4 max-w-2xl mb-12 bg-black/20 backdrop-blur-sm p-8 rounded-3xl border border-white/5">
      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-2xs font-semibold uppercase tracking-wider">
        <PlayCircle class="h-3 w-3" /> {t('filmmusic.tag')}
      </div>
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-white via-zinc-100 to-zinc-400 leading-tight" set:html={t('filmmusic.title')}>
      </h1>
      <p class="text-sm md:text-base text-[var(--color-text-secondary)] leading-relaxed max-w-xl">
        {t('filmmusic.desc')}
      </p>
    </div>

    <!-- Music List -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
      {soundtracks.map(track => {
        const Icon = track.icon;
        return (
          <div class="group relative bg-[var(--color-bg-card)] border border-[var(--color-border-apple)]/30 hover:border-blue-500/40 rounded-2xl p-6 flex flex-col justify-between transition-all duration-500 hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-500/10 overflow-hidden">
            
            <!-- Subtle background glow on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

            <div class="space-y-4 relative z-10">
              <div class="flex justify-between items-start">
                <div class="p-2.5 rounded-xl bg-blue-500/10 border border-blue-500/20 text-blue-400 shadow-inner">
                  <Icon class="h-5 w-5" />
                </div>
                <span class="text-xs font-mono text-zinc-500 bg-black/40 px-2.5 py-1 rounded-md border border-white/5">{track.year}</span>
              </div>
              
              <div>
                <h2 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors leading-snug mb-1">{track.title}</h2>
                <p class="text-xs font-medium text-zinc-400 uppercase tracking-wide">Dir. {track.director}</p>
              </div>
              
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                {track.description}
              </p>
            </div>
            
            <div class="pt-6 mt-auto relative z-10 flex items-center justify-between">
              <span class="px-2.5 py-1 text-2xs font-semibold rounded-full bg-white/5 text-zinc-300 border border-white/10">
                {track.genre}
              </span>
              
              <a href={track.url || "#"} target={track.url ? "_blank" : undefined} rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-semibold text-blue-400 hover:text-blue-300 transition-colors">
                <PlayCircle class="h-4 w-4" /> {t('filmmusic.listen')}
              </a>
            </div>
          </div>
        )
      })}

      <!-- Call to Action / Contact -->
      <div class="bg-gradient-to-br from-blue-900/40 to-black border border-blue-500/30 rounded-2xl p-6 flex flex-col justify-center items-center text-center transition-all duration-300 hover:border-blue-500/50 hover:shadow-lg hover:shadow-blue-500/20">
        <div class="p-3 rounded-full bg-blue-500/20 text-blue-400 mb-4">
          <Music class="h-6 w-6" />
        </div>
        <h3 class="text-lg font-bold text-white mb-2">{t('filmmusic.cta.title')}</h3>
        <p class="text-sm text-[var(--color-text-secondary)] mb-6 max-w-xs">
          {t('filmmusic.cta.desc')}
        </p>
        <a href="mailto:contact@example.com" class="px-5 py-2 text-xs font-bold text-white bg-blue-600 hover:bg-blue-500 rounded-full shadow-lg shadow-blue-500/25 transition-all duration-200 hover:-translate-y-0.5">
          {t('filmmusic.cta.btn')}
        </a>
      </div>
    </div>
  </section>

</Layout>
